PEACH_V1_EMA_MICRO_SLOW=
PEACH_V1_RSI_LENGTH=
PEACH_V1_RSI_MIN_LONG=
PEACH_V1_RSI_MAX_SHORT=
PEACH_V1_MIN_BARS_BETWEEN=
PEACH_V1_MIN_MOVE_PCT=

# Peach Hybrid V2 System (Momentum Surge)
PEACH_V2_EMA_FAST=
PEACH_V2_EMA_MID=
PEACH_V2_EMA_SLOW=
PEACH_V2_RSI_MOMENTUM_THRESHOLD=
