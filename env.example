# Strategy Type: "watermellon" or "peach-hybrid"
STRATEGY_TYPE=peach-hybrid

# Virtual Timeframe (milliseconds)
VIRTUAL_TIMEFRAME_MS=30000

# Risk Management
MAX_POSITION_USDT=10000
MAX_LEVERAGE=5 (10x, 20x, 50x are available for normal version) #premium support 1000x
MAX_FLIPS_PER_HOUR=12
STOP_LOSS_PCT=0
TAKE_PROFIT_PCT=0
USE_STOP_LOSS=false
EMERGENCY_STOP_LOSS_PCT=2.0
MAX_POSITIONS=1

# Watermellon Strategy Parameters (if STRATEGY_TYPE=watermellon)
EMA_FAST=
EMA_MID=
EMA_SLOW=
RSI_LENGTH=
RSI_MIN_LONG=
RSI_MAX_SHORT=

